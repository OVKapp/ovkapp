# Mall för miljövariabler. Kopiera till .env.local (lokal utveckling) och fyll i värden.
# Se DEVELOPING.md för fullständig förklaring och för produktionsmotsvarigheten (.env.production).
#
# Dessa filer läses av:
#  - supabase/seed-users-and-data.mjs (SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY)
#  - `supabase functions serve --env-file .env.local` (resten av variablerna, för Edge Functions)
# Frontend-filerna supabase-config.js / notification-config.js växlar automatiskt mellan
# lokala och produktionsvärden baserat på webbläsarens hostname (se kommentar i respektive fil).

# --- Supabase (lokal instans, se `supabase status` för exakta värden) ---
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
APP_URL=http://127.0.0.1:8080

# --- Stripe (ANVÄND ALLTID TESTNYCKLAR, sk_test_/whsec_ lokalt) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_VAT_TAX_RATE_ID=

# --- Resend (transaktionsmejl) ---
RESEND_API_KEY=
EMAIL_FROM=Procella OVK <test@localhost>

# --- Webbpush (generera lokala nycklar med supabase/generate-vapid-keys.ps1) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dev@local.test

# --- Schemalagd radering (purge-expired-brfs) ---
PURGE_CRON_SECRET=
